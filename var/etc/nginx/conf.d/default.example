# ==============================================================================
# Nginx 站点配置示例
# 适用场景：反向代理 + 静态资源 + PHP-FPM
# ==============================================================================

# upstream 后端集群（开启 keepalive 减少 TCP 握手）
upstream backend {
    server 127.0.0.1:8080 weight=1 max_fails=2 fail_timeout=10s;
    # server 127.0.0.1:8081 weight=1 max_fails=2 fail_timeout=10s;  # 扩容时添加
    keepalive 32;          # 与后端保持的长连接数
    keepalive_timeout 60s;
}

# HTTP 强制跳转 HTTPS
server {
    listen 80;
    server_name example.com www.example.com;

    return 301 https://$host$request_uri;
}

# HTTPS 主站点
server {
    listen 443 ssl http2;
    server_name example.com www.example.com;
    root /var/www/html;
    index index.php index.html;

    # SSL 证书配置
    ssl_certificate     /etc/nginx/ssl/example.com.pem;
    ssl_certificate_key /etc/nginx/ssl/example.com.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;
    ssl_stapling        on;
    ssl_stapling_verify on;

    # 静态文件 - 长缓存 + 限流保护
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|woff|woff2|svg|webp)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
        limit_conn conn_limit 20;
    }

    # API 接口 - 独立限流（比普通页面宽松）
    location /api/ {
        limit_req  zone=api_limit burst=50 nodelay;
        limit_conn conn_limit 20;

        proxy_pass http://backend;
        # proxy_* 全局已设，这里只覆盖差异项
        proxy_read_timeout 30s;  # API 通常比页面快，收紧超时
    }

    # 普通页面 - 标准限流
    location / {
        limit_req  zone=req_limit burst=20 nodelay;
        limit_conn conn_limit 20;

        try_files $uri $uri/ /index.php?$query_string;
    }

    # PHP-FPM 处理
    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_pass   unix:/var/run/php-fpm/www.sock;
        fastcgi_index  index.php;
        fastcgi_param  SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include        fastcgi_params;

        # PHP 长耗时任务（如导出）可在此单独放宽
        # fastcgi_read_timeout 300s;
    }

    # 屏蔽敏感文件
    location ~ /\.(ht|git|svn|env) {
        deny all;
    }

    # 错误页面
    error_page 404              /404.html;
    error_page 500 502 503 504  /50x.html;
    location = /50x.html { root /usr/share/nginx/html; }
}