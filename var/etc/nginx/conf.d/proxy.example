# ==============================================================================
# Nginx 反向代理配置示例
# 场景：将 example.com 流量代理到后端应用集群
# 依赖：需配合 nginx.conf 主配置使用（全局 proxy_* 参数已在主配置定义）
# ==============================================================================

# ------------------------------------------------------------------------------
# 后端集群定义
# 建议按业务模块拆分 upstream，便于独立扩缩容和熔断
# ------------------------------------------------------------------------------

# Web 应用主服务（Node.js / Java / Go 等）
upstream app_backend {
    # 负载均衡策略：默认轮询；可改为 least_conn（推荐长连接场景）
    least_conn;

    server 127.0.0.1:8080 weight=1 max_fails=2 fail_timeout=10s;
    server 127.0.0.1:8081 weight=1 max_fails=2 fail_timeout=10s;
    # server 10.0.0.2:8080  weight=2 max_fails=2 fail_timeout=10s;  # 跨机器节点

    # 与后端保持长连接，避免每次请求重新 TCP 握手
    keepalive 32;
    keepalive_timeout 60s;
    keepalive_requests 1000;
}

# API 服务（可独立扩容）
upstream api_backend {
    least_conn;
    server 127.0.0.1:9090 weight=1 max_fails=2 fail_timeout=10s;
    server 127.0.0.1:9091 weight=1 max_fails=2 fail_timeout=10s;
    keepalive 64;
    keepalive_timeout 60s;
}

# WebSocket 服务
upstream ws_backend {
    ip_hash;  # WebSocket 需要会话保持，使用 ip_hash
    server 127.0.0.1:7070;
    server 127.0.0.1:7071;
    keepalive 16;
}

# ------------------------------------------------------------------------------
# HTTP → HTTPS 强制跳转
# ------------------------------------------------------------------------------
server {
    listen 80;
    listen [::]:80;
    server_name example.com www.example.com;

    # ACME 证书续签验证（Let's Encrypt）
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ------------------------------------------------------------------------------
# 主 HTTPS 服务
# ------------------------------------------------------------------------------
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name example.com www.example.com;

    # --------------------------------------------------------------------------
    # SSL/TLS
    # --------------------------------------------------------------------------
    ssl_certificate         /etc/nginx/ssl/example.com.fullchain.pem;
    ssl_certificate_key     /etc/nginx/ssl/example.com.key;

    ssl_protocols           TLSv1.2 TLSv1.3;
    ssl_ciphers             ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;  # TLS 1.3 下关闭，让客户端选择最优套件

    ssl_session_cache       shared:SSL:10m;
    ssl_session_timeout     1d;
    ssl_session_tickets     off;    # 禁用 ticket，提升前向安全性

    ssl_stapling            on;     # OCSP 装订，加速 TLS 握手
    ssl_stapling_verify     on;
    ssl_trusted_certificate /etc/nginx/ssl/example.com.chain.pem;
    resolver                8.8.8.8 8.8.4.4 valid=300s;
    resolver_timeout        5s;

    # --------------------------------------------------------------------------
    # 访问日志（单站点可独立存放）
    # --------------------------------------------------------------------------
    access_log /var/log/nginx/example.com.access.log main buffer=32k flush=5s;
    error_log  /var/log/nginx/example.com.error.log  warn;

    # --------------------------------------------------------------------------
    # 安全响应头（覆盖主配置，按业务需求调整）
    # --------------------------------------------------------------------------
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options           "SAMEORIGIN"                           always;
    add_header X-Content-Type-Options    "nosniff"                              always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin"      always;

    # --------------------------------------------------------------------------
    # 静态资源（直接由 Nginx 服务，不走后端）
    # --------------------------------------------------------------------------
    root /var/www/example.com/public;

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|woff|woff2|svg|webp|avif|ttf|eot)$ {
        expires    30d;
        add_header Cache-Control "public, immutable";
        add_header Vary "Accept-Encoding";
        access_log off;                # 静态资源日志意义不大，关闭节省 I/O
        limit_conn conn_limit 20;
    }

    # favicon 和 robots 单独处理，避免刷 404 日志
    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    # --------------------------------------------------------------------------
    # WebSocket 代理
    # --------------------------------------------------------------------------
    location /ws/ {
        proxy_pass http://ws_backend;

        # WebSocket 握手必须的 header
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host       $host;
        proxy_set_header X-Real-IP  $remote_addr;

        # WebSocket 长连接，超时要放宽
        proxy_read_timeout    3600s;
        proxy_send_timeout    3600s;
        proxy_connect_timeout 10s;

        limit_conn conn_limit 10;
    }

    # --------------------------------------------------------------------------
    # API 接口代理（独立限流 + 独立后端）
    # --------------------------------------------------------------------------
    location /api/ {
        limit_req  zone=api_limit burst=50 nodelay;
        limit_conn conn_limit 30;

        proxy_pass http://api_backend;  # 注意：末尾无 /，保留原始 URI 前缀

        # API 通常响应快，收紧超时，快速发现后端故障
        proxy_connect_timeout 5s;
        proxy_read_timeout    30s;
        proxy_send_timeout    30s;

        # API 响应通常不大，可关闭缓冲降低首字节时间
        proxy_buffering off;

        # 跨域支持（若前后端分离则启用）
        # add_header Access-Control-Allow-Origin  "$http_origin" always;
        # add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        # add_header Access-Control-Allow-Headers "Authorization, Content-Type" always;
        # add_header Access-Control-Allow-Credentials "true" always;
        # if ($request_method = OPTIONS) { return 204; }
    }

    # --------------------------------------------------------------------------
    # 健康检查端点（供负载均衡器或 k8s 探针使用，不限流、不鉴权）
    # --------------------------------------------------------------------------
    location = /health {
        access_log off;
        proxy_pass http://app_backend;
        proxy_read_timeout 5s;
    }

    # --------------------------------------------------------------------------
    # 主应用代理（兜底 location）
    # --------------------------------------------------------------------------
    location / {
        limit_req  zone=req_limit burst=20 nodelay;
        limit_conn conn_limit 20;

        proxy_pass http://app_backend;

        # 后端返回 30x 时，将 Location header 中的后端地址替换为对外域名
        proxy_redirect ~^http://127\.0\.0\.1:\d+(/.*)$ https://$host$1;

        # 超时
        proxy_connect_timeout 10s;
        proxy_read_timeout    60s;
        proxy_send_timeout    60s;

        # 缓存后端响应（需要 proxy_cache_path 配合，见下方注释）
        # proxy_cache          app_cache;
        # proxy_cache_valid    200 302 10m;
        # proxy_cache_valid    404     1m;
        # proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        # add_header X-Cache-Status $upstream_cache_status;
    }

    # --------------------------------------------------------------------------
    # 屏蔽敏感路径
    # --------------------------------------------------------------------------
    location ~ /\.(ht|git|svn|env|DS_Store) {
        deny all;
    }
    location ~ \.(sql|log|bak|sh|conf)$ {
        deny all;
    }

    # --------------------------------------------------------------------------
    # 错误页
    # --------------------------------------------------------------------------
    error_page 404             /404.html;
    error_page 500 502 503 504 /50x.html;
    location = /50x.html { root /usr/share/nginx/html; internal; }
}

# ------------------------------------------------------------------------------
# 可选：Proxy Cache 配置（在 http 块中添加，此处仅作参考注释）
# 若要启用，请将以下内容移入 nginx.conf 的 http {} 块
# ------------------------------------------------------------------------------
# proxy_cache_path /var/cache/nginx/app
#     levels=1:2
#     keys_zone=app_cache:10m
#     max_size=1g
#     inactive=60m
#     use_temp_path=off;