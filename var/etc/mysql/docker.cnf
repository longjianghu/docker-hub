# ==============================================================================
# MySQL 生产环境配置（Docker 混部版）
# 环境：8G 宿主机内存，与其他服务混部，容器内存限制建议 4~5G
# 场景：业务数据库，读写均衡
# 版本：MySQL 8.0
# ==============================================================================

[mysqld]

# ------------------------------------------------------------------------------
# 基础设置
# ------------------------------------------------------------------------------

# 跳过 DNS 反向解析，加速连接建立（host 列需用 IP，不能用域名）
skip-name-resolve

# 主从复制必须唯一，单机可保持 1
server_id = 1

# 数据和错误日志目录（对应 Docker volumes 挂载路径）
datadir = /var/lib/mysql
socket  = /var/run/mysqld/mysqld.sock

# 字符集（全部统一 utf8mb4，避免乱码）
character_set_server   = utf8mb4
collation_server       = utf8mb4_unicode_ci
init_connect           = 'SET NAMES utf8mb4'

# 时区（按实际情况修改）
default_time_zone = '+8:00'

# TIMESTAMP 列显式默认值，避免隐式行为
explicit_defaults_for_timestamp = ON

# ------------------------------------------------------------------------------
# 连接管理
# ------------------------------------------------------------------------------

# 最大连接数
# 8G 混部环境，MySQL 约占 4~5G，每连接约 1MB 线程栈
# 2000 连接理论需 2G，混部场景建议控制在 500~800
max_connections        = 500
max_connect_errors     = 10000       # 同一 IP 连续失败次数上限，超过则封禁

# 连接超时（清理僵尸连接）
wait_timeout           = 600         # 非交互连接空闲超时（秒）
interactive_timeout    = 600         # 交互连接空闲超时（秒）
connect_timeout        = 10          # 建立连接超时

# 连接队列（对应 tcp backlog）
back_log               = 1024

# ------------------------------------------------------------------------------
# InnoDB 核心参数（最影响性能的部分）
# ------------------------------------------------------------------------------

# Buffer Pool：8G 混部，MySQL 容器限 4~5G，buffer pool 设 3G
# 公式：容器内存限制 × 65% 左右
innodb_buffer_pool_size     = 3G

# Buffer Pool 实例数：每个实例约 1G，减少锁竞争
# 3G / 1G = 3 个实例
innodb_buffer_pool_instances = 3

# Redo Log（MySQL 8.0.30+ 自动管理，无需手动设置 innodb_log_file_size）
# MySQL 8.0.30 以下版本请取消注释：
# innodb_log_file_size        = 512M   # 建议 buffer pool 的 25%，上限 2G
# innodb_log_files_in_group   = 2

# Redo Log Buffer（事务提交前的内存缓冲）
innodb_log_buffer_size      = 64M

# 刷盘策略（最重要的持久化配置）
# 1 = 每次提交都 fsync，最安全，性能最低（金融级场景）
# 2 = 每次提交写 OS 缓存，每秒 fsync，宕机最多丢 1 秒数据（推荐）
# 0 = 每秒写 + fsync，性能最好，MySQL 崩溃可能丢数据
innodb_flush_log_at_trx_commit = 1

# I/O 模式（Linux 推荐 O_DIRECT，跳过 OS 页缓存，避免双重缓冲）
innodb_flush_method         = O_DIRECT

# 后台 I/O 线程数（SSD 建议 4~8，HDD 建议 2）
innodb_read_io_threads      = 4
innodb_write_io_threads     = 4

# 每秒 I/O 能力上限（SSD 设 2000~4000，HDD 设 200~800）
# Docker 容器内通常是 SSD，根据实际磁盘性能调整
innodb_io_capacity          = 2000
innodb_io_capacity_max      = 4000

# 脏页比例上限，超过触发强制刷盘（默认 90，适当降低避免 I/O 突刺）
innodb_max_dirty_pages_pct  = 75

# Change Buffer（非唯一索引写入缓冲，读写均衡场景用 all）
innodb_change_buffering     = all
innodb_change_buffer_max_size = 25  # 占 buffer pool 百分比

# 在线 DDL 临时文件目录（默认 tmpdir，大表 DDL 需要足够磁盘空间）
# innodb_tmpdir = /tmp

# 死锁检测（高并发写入时可关闭以提升性能，但关闭后死锁只能靠超时解决）
innodb_deadlock_detect      = ON
innodb_lock_wait_timeout    = 10    # 锁等待超时（秒）

# 行格式（DYNAMIC 支持大索引前缀，utf8mb4 必须用）
innodb_default_row_format   = DYNAMIC

# ------------------------------------------------------------------------------
# 内存相关（防止 OOM）
# ------------------------------------------------------------------------------

# 单次排序缓冲（每个连接独占，500 连接 × 2M = 1G，谨慎调大）
sort_buffer_size            = 2M

# 连接读取缓冲
read_buffer_size            = 1M
read_rnd_buffer_size        = 2M

# JOIN 操作 Hash 缓冲（MySQL 8.0 BNL 已被 Hash Join 替代）
join_buffer_size            = 2M

# 线程栈大小
thread_stack                = 256K

# 内存临时表上限，超过则转磁盘临时表
tmp_table_size              = 64M
max_heap_table_size         = 64M

# 单个数据包最大值（导入大数据或大字段时可能需要调大）
max_allowed_packet          = 64M

# 表缓存（打开表的文件描述符缓存，连接数多时适当调大）
table_open_cache            = 2000
table_definition_cache      = 1000
open_files_limit            = 65535

# ------------------------------------------------------------------------------
# 二进制日志（主从复制 + PITR 必须开启）
# ------------------------------------------------------------------------------

# 开启 binlog
log_bin                     = /var/log/mysql/mysql-bin
binlog_format               = ROW              # 行模式，最安全，推荐

# Binlog 保留时间：10 天（单位秒）
binlog_expire_logs_seconds  = 864000

# 每个 binlog 文件最大大小
max_binlog_size             = 512M

# ROW 格式下只记录变更的列（减少 binlog 体积）
binlog_row_image            = MINIMAL

# 事务提交时同步 binlog 到磁盘
# 1 = 最安全（每次提交 fsync），与 innodb_flush_log_at_trx_commit=1 配合使用
# 100~1000 = 性能更好，但主库崩溃可能丢少量事务
sync_binlog                 = 1

# GTID（主从复制强烈建议开启，便于切换主库和 binlog 定位）
gtid_mode                   = ON
enforce_gtid_consistency    = ON

# ------------------------------------------------------------------------------
# 慢查询日志
# ------------------------------------------------------------------------------

slow_query_log              = ON
slow_query_log_file         = /var/log/mysql/mysql-slow.log
long_query_time             = 1.0              # 超过 1 秒记录
log_queries_not_using_indexes = ON             # 未走索引的查询也记录
log_throttle_queries_not_using_indexes = 10   # 每分钟最多记录 10 条未走索引的查询（防日志膨胀）
min_examined_row_limit      = 100              # 扫描行数少于 100 的不记录（过滤无意义的小查询）

# ------------------------------------------------------------------------------
# 错误日志
# ------------------------------------------------------------------------------

log_error                   = /var/log/mysql/mysql-error.log
log_error_verbosity         = 2               # 1=error, 2=error+warning, 3=全部

# ------------------------------------------------------------------------------
# 性能优化
# ------------------------------------------------------------------------------

# 查询缓存（MySQL 8.0 已彻底移除，无需设置）

# 线程缓存（减少频繁创建销毁线程的开销）
thread_cache_size           = 100

# 事务隔离级别（默认 REPEATABLE-READ，读写均衡场景可用）
transaction_isolation       = REPEATABLE-READ

# 索引统计信息采样页数（越大越准确，但 ANALYZE TABLE 越慢）
innodb_stats_persistent_sample_pages = 25

# 自动更新统计信息（建议开启，保证执行计划准确）
innodb_stats_auto_recalc    = ON

# 双写缓冲（防止页面部分写，文件系统支持原子写时可关闭，一般保持开启）
innodb_doublewrite          = ON

# ------------------------------------------------------------------------------
# Docker 容器特殊配置
# ------------------------------------------------------------------------------

# 容器内 PID 1 通常是 mysqld 本身，不需要 pid 文件
# pid_file = /var/run/mysqld/mysqld.pid

# 容器日志输出到文件（通过 volume 挂载持久化）
# 如果使用 Docker logging driver 收集日志，可将 log_error 改为 stderr：
# log_error = stderr

[client]
default-character-set = utf8mb4
socket = /var/run/mysqld/mysqld.sock

[mysql]
default-character-set = utf8mb4

# ==============================================================================
# Docker Compose 参考配置
# ==============================================================================
#
# services:
#   mysql:
#     image: mysql:8.0
#     container_name: mysql
#     restart: unless-stopped
#     ports:
#       - "127.0.0.1:3306:3306"     # 只绑定宿主机本地
#     environment:
#       MYSQL_ROOT_PASSWORD: your_strong_password
#       MYSQL_DATABASE: your_db
#     volumes:
#       - /opt/mysql/data:/var/lib/mysql
#       - /opt/mysql/logs:/var/log/mysql
#       - /opt/mysql/my.cnf:/etc/mysql/conf.d/my.cnf:ro
#     deploy:
#       resources:
#         limits:
#           memory: 5g              # 比 buffer_pool(3G) + 其他内存开销留足余量
#           cpus: '2'
#     healthcheck:
#       test: ["CMD", "mysqladmin", "ping", "-h", "127.0.0.1", "-uroot", "-pyour_strong_password"]
#       interval: 10s
#       timeout: 5s
#       retries: 3
#       start_period: 30s
#     logging:
#       driver: "json-file"
#       options:
#         max-size: "200m"
#         max-file: "5"
#
# ==============================================================================
# 宿主机内核参数（在宿主机执行，写入 /etc/sysctl.conf 永久生效）
# ==============================================================================
#
#   vm.swappiness = 10              # 减少使用 swap，优先使用物理内存
#   vm.dirty_ratio = 15             # 脏页比例超过 15% 触发刷盘
#   vm.dirty_background_ratio = 5  # 后台刷盘触发比例
#   net.core.somaxconn = 65535
#   net.ipv4.tcp_max_syn_backlog = 65535
